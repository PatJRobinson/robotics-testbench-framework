{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sim.platform.app.v0.2",
  "title": "sim-platform App",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "sim.platform/v0.2"
    },
    "kind": {
      "const": "App"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "spec": {
      "type": "object",
      "required": ["runtime", "requires"],
      "additionalProperties": true,
      "properties": {
        "category": { "type": "string" },
        "runtime": {
          "type": "object",
          "required": ["type", "entrypoint"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["shell", "python", "ros2_node"]
            },
            "entrypoint": {
              "type": "string",
              "minLength": 1
            },
            "interactive": {
              "type": "boolean"
            }
          }
        },
        "requires": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "platforms": {
              "$ref": "#/$defs/contractList"
            },
            "commands": {
              "$ref": "#/$defs/contractListWithBindingConfig"
            },
            "observations": {
              "$ref": "#/$defs/contractListWithBindingConfig"
            }
          }
        },
        "optional": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "platforms": {
              "$ref": "#/$defs/contractList"
            },
            "commands": {
              "$ref": "#/$defs/contractListWithBindingConfig"
            },
            "observations": {
              "$ref": "#/$defs/contractListWithBindingConfig"
            }
          }
        },
        "behaviour": {
          "type": "object",
          "additionalProperties": true
        },
        "provides": {
          "type": "object",
          "additionalProperties": true
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": true
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "contractRef": {
      "type": "object",
      "required": ["contract"],
      "additionalProperties": false,
      "properties": {
        "contract": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contractBindingConfigRef": {
      "type": "object",
      "required": ["contract"],
      "additionalProperties": false,
      "properties": {
        "contract": {
          "type": "string",
          "minLength": 1
        },
        "bindingConfig": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "contractList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contractRef"
      }
    },
    "contractListWithBindingConfig": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contractBindingConfigRef"
      }
    }
  }
}
