{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sim.platform.contract.v0.2",
  "title": "sim-platform Contract",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "sim.platform/v0.2"
    },
    "kind": {
      "const": "Contract"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "spec": {
      "type": "object",
      "required": ["contractType"],
      "additionalProperties": true,
      "properties": {
        "contractType": {
          "type": "string",
          "enum": ["platform", "command", "observation"]
        },
        "semantics": {
          "type": "object",
          "additionalProperties": true
        },
        "representation": {
          "type": "object",
          "additionalProperties": true
        },
        "compatibleCommandContracts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "intendedPlatforms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
